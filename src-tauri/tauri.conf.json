{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "dear-agent-panel",
  "version": "0.1.0",
  "identifier": "com.tauri-app.dear-agent-panel",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "dear-agent-panel",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "capabilities": [
        "default",
        {
          "identifier": "allow-create-live2d-webview-window",
          "description": "Allow frontend to create standalone Live2D webview windows",
          "windows": [
            "main"
          ],
          "permissions": [
            "core:webview:default",
            "core:webview:allow-create-webview-window",
            "core:window:allow-show",
            "core:window:allow-set-focus",
            "core:window:allow-set-always-on-top"
          ]
        }
      ],
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
